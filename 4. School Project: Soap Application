#fonction pour afficher le camembert d'un savon
def afficherCamembertSavon(choixMontrerIndexSavon):
    compositionSavon = listeDesSavons[choixMontrerIndexSavon-1][4]

    labels = [item[0] for item in compositionSavon] #récuperer le nom des ingrédients
    values = [item[1] for item in compositionSavon] #récupérer la masse des ingrédients

    totalMasse = sum(values)

    labelsAvecMasseEtPourcentage = [] #création des labels du graphe avec masse et pourcentage
    
    for i in compositionSavon: #pour chaque ingredient
        nomIngredient = i[0]
        masse = i[1]
        pourcentage = (masse/totalMasse)*100
        labelsAvecMasseEtPourcentage.append(
            nomIngredient + " :" + str(masse) + " g (" + str(round(pourcentage,1)) + "%)"  )

    plt.figure()
    plt.title("Composition du " + listeDesSavons[choixMontrerIndexSavon-1][3] + 
              " fait par " + listeDesSavons[choixMontrerIndexSavon-1][1] + " " + #prénom
                          listeDesSavons[choixMontrerIndexSavon-1][2]) #nom
    plt.pie(values, labels = labelsAvecMasseEtPourcentage)
    plt.show()
