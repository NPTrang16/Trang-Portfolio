#fonction créer un savon
def creerSavon():
    positionSavon = 1 #initialisation de l'ID du savon dans la listeDesSavons
    print("Vous allez créer un nouveau savon")
    
    prenomLaborantin = input("Votre prénom: ")
    nomLaborantin = input("Votre nom : ")
    nomSavon = input("Donnez un nom à votre savon : ")
    
    positionSavon = positionSavon+1
    
    afficherListeHuile() #fonction afficher la liste des huiles
    
    while True:
        huileIDchoisi = int(input(
            "Choisissez une huile de la liste (0 pour revenir au menu principal, -1 pour rentrer la soude) : "))
        
        if huileIDchoisi == 0:
            print("Retour au menu principal")
            break
        
        elif 1<= huileIDchoisi <= 10: #si l'user a choisi une huile

            print("Vous avez choisi: ", huiles[huileIDchoisi-1][1]) #confirmer le nom de l'ingrédient
            masseHuile = float(input("Masse de " + huiles[huileIDchoisi-1][1] + " (en g) :")) #demander la masse d'huile
            volumeHuile = masseHuile / huiles[huileIDchoisi-1][4] #calculer le volume de l'huile
            listeDesIngredientsUtilises.append((huiles[huileIDchoisi-1][1], masseHuile)) #ajouter dans la liste des ingrédients
            print("Utilisation de", huiles[huileIDchoisi-1][1], round( volumeHuile, 2), "mL")
            
        elif huileIDchoisi == -1: #faire les calculs de la soude
            print("Calcul de la soude théorique: ")
            soudeTheorique = soudeTheoriqueTotale(listeDesIngredientsUtilises,huiles)
           
            
            print("Soude théorique totale: ", round(soudeTheorique,2), " g")
            
            demanderSoudeReelle(soudeTheorique) #demander la soude réelle + calcul du taux de graisse + finaliser la soude dans la formulation
            
            IngredsSupplementaires() #demander d'ajouter un autre ingrédient si l'user veut
            
            listeDesSavons.append((positionSavon, prenomLaborantin,nomLaborantin, nomSavon, listeDesIngredientsUtilises))
            
            
            break #sortir de la boucle pour revenir à la page d'accueil
            
            
        else:
            print("Erreur: veuillez choisir un nombre entre 0 et 10")
    
