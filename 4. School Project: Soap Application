#fonction pour calculer la soude théorique
def soudeTheoriqueTotale(listeDesIngredientsUtilises,huiles):
    soudeTotaleTheorique = 0
    for i in listeDesIngredientsUtilises: #parcourir la liste des ingrédients
        nomHuileUtilisee = i[0]
        masseHuileUtilisee = i[1]
        for x in huiles: #parcourir la liste des huiles initiale pour voir si ca match
            if x[1] == nomHuileUtilisee:
                indiceSAP = x[5]
                soudeIndividuelle = (masseHuileUtilisee*indiceSAP)/1000 
                print(nomHuileUtilisee, ":", masseHuileUtilisee, "g → NaOH = ", soudeIndividuelle, "g")
                soudeTotaleTheorique = soudeIndividuelle + soudeTotaleTheorique
                break
    return soudeTotaleTheorique
#-----------------------------------------------------------------------------
#fonction pour demaRnder la masse de soude réelle
def demanderSoudeReelle(soudeTheorique):
    #soudeTheorique = soudeTheoriqueTotale(listeDesIngredientsUtilises,huiles)
    soudeReelle = None
    while True:
        reponseSoude = input("Voulez-vous faire un diagnostique de votre savon?:  ")
        
        if reponseSoude.lower() != "non":
            
            soudeReelle = float(input("Masse de soude réelle utilisée (en g): "))
            taux = calculSurgraissage(soudeReelle,soudeTheorique)
            print("Taux de surgraissage: ", round(taux,2), "%")
            print(diagnostic(taux))
        else:
            listeDesIngredientsUtilises.append(("Soude", soudeReelle))
            break
#-----------------------------------------------------------------------------
#fonction pour calculer le taux de surgraissage
def calculSurgraissage(soudeReelle,soudeTheorique):
    return(1-soudeReelle/soudeTheorique)*100

#-----------------------------------------------------------------------------
#fonction pour diagnostiquer
def diagnostic(taux):
    if taux < 0:
        return("savon caustique")
    elif taux < 5:
        return("marge de sécurité non respectée")
    elif taux < 8:
        return ("peu surgras")
    elif taux < 10:
        return ("surgras (doux, idéal)")
    elif taux <= 12:
        return ("très surgras")
    else:
        return ("trop riche en huile")
